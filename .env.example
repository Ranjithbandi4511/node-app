PORT=5000

# Run app on your machine (npm run dev) — MongoDB exposed on host port 27017
MONGODB_URI=mongodb://admin:qwerty@localhost:27017/?authSource=admin

# Run app inside Docker on same network as mongo service — use hostname "mongo" instead:
# MONGODB_URI=mongodb://admin:qwerty@mongo:27017/?authSource=admin

MONGODB_DB=dental-db
